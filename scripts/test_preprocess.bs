import sklearn_brane;

on "worker1" {
    println("Loading dataset...");
    let data := new Data { name := "breast_cancer" };

    println("Splitting data...");
    let split := load_and_split(data, "target", "0.2");

    println("Scaling features...");
    let scaled := scale_features(split, "standard");

    println("Saved split files to /result/X_train.csv, /result/X_test.csv, /result/y_train.csv, /result/y_test.csv");
    println("Saved scaled data to /result and scaler to /result/scaler.joblib");
    println(split);
    println(scaled);
}
