import sklearn_viz;

on "worker1" {
    println("Loading core branch bundles...");
    let rf_bundle := new Data { name := "core_rf_branch" };
    let lr_bundle := new Data { name := "core_lr_branch" };

    println("Bundling core results...");
    let results := bundle_core_results(rf_bundle, lr_bundle, "target");

    println("Committing core result as core_results...");
    return commit_result("core_results", results);
}
